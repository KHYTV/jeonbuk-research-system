# ───────────────────────────────────────────────────────────────
#  전북 연구 시스템 환경변수 — 이 파일을 복사해 ".env" 로 저장 후 채우세요
#  키가 없는 항목은 해당 수집기가 자동으로 Mock 으로 폴백합니다
# ───────────────────────────────────────────────────────────────

# data.go.kr 공통 인증키 (1개로 소상공인·식약처·에어코리아·HIRA 커버)
DATAGOKR_API_KEY=

# 통계청 KOSIS (인구이동·출생·사망)
KOSIS_API_KEY=

# 한국관광공사 TourAPI (음식점·행사·관광지)
TOURAPI_KEY=

# 카카오 로컬 REST API (장소 검색)
KAKAO_REST_KEY=

# 네이버 검색 API (뉴스·지역검색) — developers.naver.com, 무료
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# 빅카인즈 (뉴스 빅데이터) — 2025~ 유료 전환, 선택
BIGKINDS_API_KEY=

# Anthropic Claude (분석기사 자동작성) — 없으면 규칙기반 템플릿 초안으로 폴백
ANTHROPIC_API_KEY=
